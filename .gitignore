.DS_Store
*.pem

# Credentials (APNs keys, certificates)
credentials/
credentials.json

# local env files
.env
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders (tracked because we have custom native code)
# /ios
# /android

